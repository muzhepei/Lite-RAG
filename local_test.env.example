# 复制为 local_test.env 后按需修改（local_test.env 建议加入 .gitignore）
# 连接参数由 es2vec/es_client.py 读取，无需外部 word2vec 目录。

ES_HOST=https://localhost:9200
ES_USER=elastic
ES_PASSWORD=你的elastic密码

ES_VERIFY_CERTS=false

# --- 本地向量模型（索引与搜索共用）---
# 下载模型请自行使用 huggingface-cli 或 SentenceTransformer；目录示例：
#   D:\models\multilingual-e5-small
# ES2VEC_HF_LOCAL_FILES_ONLY 未写时程序默认按 1（仅本地）；需 Hub 在线下载时写：
# ES2VEC_HF_LOCAL_FILES_ONLY=0
# HF_ENDPOINT=https://hf-mirror.com
# ES2VEC_LOCAL_MODEL=D:\models\multilingual-e5-small

# --- 可选：Elasticsearch Synonyms API 同义词集 id（与 cli/put_synonyms_set.py / index_corpus --synonyms-set-id 一致）---
# ES2VEC_SYNONYMS_SET=es2vec_cn

# --- 可选：混合检索 / 人名误排调优（Web 默认 vec=0.85 kw=0.15 kw_sat=25；CLI 默认 0.7/0.3/15）---
# ES2VEC_VEC_WEIGHT=0.85
# ES2VEC_KW_WEIGHT=0.15
# ES2VEC_KW_SAT=25
# ES2VEC_NAME_RERANK=1
# ES2VEC_NAME_RERANK_AUTO=1
# ES2VEC_NAME_RERANK_POOL=50
# 人名检索推荐索引名（chunk 级）：
# ES2VEC_INDEX=es2vec_corpus_chunks

# --- 可选：OpenAI 兼容 Embeddings（index_corpus / search_hybrid 加 --use-openai-compatible-embedding）---
# 百炼（推荐）：只设 DASHSCOPE_API_KEY 且不要写 ES2VEC_OPENAI_BASE_URL 时，会自动使用
#   https://dashscope.aliyuncs.com/compatible-mode/v1 与模型 text-embedding-v4
# 魔搭推理：设置 MODELSCOPE_API_KEY（或 API_KEY），并显式指定：
# ES2VEC_OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
# ES2VEC_OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# DASHSCOPE_API_KEY=百炼_API_Key
# MODELSCOPE_API_KEY=魔搭_Token
# 兼容（按序仅取第一个非空）：DASHSCOPE_API_KEY、API_KEY、OPENAI_API_KEY、MODELSCOPE_API_KEY
# 值里不要写「Bearer 」前缀
# ES2VEC_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# ES2VEC_DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# ES2VEC_DASHSCOPE_EMBEDDING_BATCH_MAX=10
# ES2VEC_EMBEDDING_DIMS=1024
