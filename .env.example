# Docker Compose / ECS 部署环境变量模板
# 使用：cp .env.example .env  →  编辑 .env  →  docker compose up -d
# .env 已加入 .gitignore，勿提交真实密码与 API Key。
#
# Compose 会用本文件做 ${变量} 替换，并通过 env_file 注入 es2vec / web / grpc 容器。
# 本机直接 python cli/... 请用 local_test.env.example → local_test.env（二者用途不同）。

# =============================================================================
# 必改（生产勿使用默认 es2vec_dev）
# =============================================================================
ELASTIC_PASSWORD=es2vec_dev

# =============================================================================
# 服务端口（宿主机映射；安全组按需放行，建议公网仅开放 Web 端口）
# =============================================================================
ES2VEC_WEB_PORT=8765
ES2VEC_GRPC_PORT=50051

# =============================================================================
# 检索默认索引（须与 index_corpus --index 一致；chunk 人名检索推荐如下）
# =============================================================================
ES2VEC_INDEX=es2vec_corpus_chunks

# =============================================================================
# 向量模型（首次 index_corpus 会从 Hub 下载，缓存到 hf_cache 卷）
# =============================================================================
# 0=允许在线下载；1=仅本地（需已缓存或挂载模型目录）
ES2VEC_HF_LOCAL_FILES_ONLY=0
# 国内 ECS 必填（compose 已默认 hf-mirror；也可在此显式写出）
HF_ENDPOINT=https://hf-mirror.com
# ES2VEC_LOCAL_MODEL=intfloat/multilingual-e5-small

# =============================================================================
# 可选：混合检索调优（Web 默认 vec=0.85 kw=0.15 kw_sat=25）
# =============================================================================
# ES2VEC_VEC_WEIGHT=0.85
# ES2VEC_KW_WEIGHT=0.15
# ES2VEC_KW_SAT=25
# ES2VEC_NAME_RERANK_AUTO=1
# ES2VEC_NAME_RERANK_POOL=50

# =============================================================================
# 可选：RAG 问答（Web POST /api/v1/rag；不配则仅混合检索可用）
# 百炼：只设 DASHSCOPE_API_KEY 且不设 ES2VEC_OPENAI_BASE_URL 时自动走 compatible-mode
# =============================================================================
# DASHSCOPE_API_KEY=
# ES2VEC_CHAT_MODEL=qwen-turbo
# ES2VEC_DASHSCOPE_CHAT_MODEL=qwen-plus
# ES2VEC_RAG_TOP_K=3
# ES2VEC_RAG_MAX_CONTEXT_CHARS=12000
# ES2VEC_RAG_MAX_TOKENS=1024
# ES2VEC_CHAT_TEMPERATURE=0.3

# =============================================================================
# 可选：OpenAI 兼容 Embeddings（index_corpus 加 --use-openai-compatible-embedding 时使用）
# =============================================================================
# MODELSCOPE_API_KEY=
# ES2VEC_OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1
# ES2VEC_OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# ES2VEC_EMBEDDING_DIMS=1024

# =============================================================================
# 可选：同义词集（与 cli/put_synonyms_set.py、index_corpus --synonyms-set-id 一致）
# =============================================================================
# ES2VEC_SYNONYMS_SET=es2vec_cn
